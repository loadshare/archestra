{
  "request": {
    "method": "POST",
    "urlPath": "/mcp/jwks-cred-priority-e2e",
    "bodyPatterns": [
      { "matchesJsonPath": "$[?(@.method == 'tools/call')]" }
    ]
  },
  "response": {
    "status": 200,
    "headers": { "Content-Type": "application/json" },
    "body": "{\"jsonrpc\":\"2.0\",\"id\":{{jsonPath request.body '$.id'}},\"result\":{\"content\":[{\"type\":\"text\",\"text\":\"RECEIVED_AUTH={{request.headers.Authorization}}\"}]}}"
  }
}
